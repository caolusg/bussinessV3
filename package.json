{
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "cd apps/api && npm run prisma:migrate:deploy",
    "db:seed": "npm --prefix apps/api run db:seed",
    "db:seed:content": "npm --prefix apps/api run db:seed:content",
    "prod:up": "docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build",
    "prod:down": "docker compose --env-file .env.production -f docker-compose.prod.yml down",
    "prod:logs": "docker compose --env-file .env.production -f docker-compose.prod.yml logs -f",
    "prod:migrate": "docker compose --env-file .env.production -f docker-compose.prod.yml run --rm api npm run prisma:migrate:deploy",
    "prod:seed": "docker compose --env-file .env.production -f docker-compose.prod.yml run --rm api npm run db:seed",
    "prod:seed:content": "docker compose --env-file .env.production -f docker-compose.prod.yml run --rm api npm run db:seed:content",
    "api:dev": "npm --prefix apps/api run dev",
    "api:build": "npm --prefix apps/api run build",
    "web:dev": "npm --prefix apps/web run dev",
    "web:build": "npm --prefix apps/web run build"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
