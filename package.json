{
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "cd apps/api && npm run prisma:migrate:deploy",
    "db:seed": "npm --prefix apps/api run db:seed",
    "api:dev": "npm --prefix apps/api run dev",
    "api:build": "npm --prefix apps/api run build",
    "web:dev": "npm --prefix apps/web run dev",
    "web:build": "npm --prefix apps/web run build"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
