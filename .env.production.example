POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=bussinessv3
CONTAINER_REGISTRY_MIRROR=
APT_MIRROR=

JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10
APP_BASE_URL=https://your-domain.example.com
EMAIL_VERIFICATION_REQUIRED=true
EMAIL_VERIFICATION_EXPIRES_HOURS=24
PASSWORD_RESET_EXPIRES_MINUTES=60
MAIL_MODE=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=Business Chinese Simulator <no-reply@your-domain.example.com>

DEFAULT_TEACHER_USERNAME=teacher
DEFAULT_TEACHER_PASSWORD=change_me_teacher_password

AI_ENABLED=true
AI_PROVIDER=deepseek
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
AI_API_KEY=
AI_TIMEOUT_MS=15000
AI_PROXY_URL=

WEB_PORT=80

# Only needed if your frontend and API are on different origins.
# For same-domain deployment through the bundled nginx reverse proxy, leave blank.
CORS_ORIGINS=
